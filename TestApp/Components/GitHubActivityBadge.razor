@implements IDisposable

@if (stats is not null)
{
    <div class="gh-badge">
        @if (stats.StargazersCount > 0)
        {
            <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/></svg>
            <span>@stats.StargazersCount</span>
            <span class="gh-badge-sep" aria-hidden="true">·</span>
        }
        <span>@UpdatedText</span>
    </div>
}

@code {
    [Parameter, EditorRequired]
    public string Repo { get; set; } = "";

    private RepoStats? stats;

    protected override void OnInitialized() => SiteContent.LanguageChanged += StateHasChanged;

    public void Dispose() => SiteContent.LanguageChanged -= StateHasChanged;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            using var client = new HttpClient { Timeout = TimeSpan.FromSeconds(5) };
            client.DefaultRequestHeaders.UserAgent.ParseAdd("MoritzWaldau-Portfolio");
            client.DefaultRequestHeaders.Accept.Add(
                new System.Net.Http.Headers.MediaTypeWithQualityHeaderValue("application/vnd.github+json"));
            stats = await client.GetFromJsonAsync<RepoStats>($"https://api.github.com/repos/{Repo}");
        }
        catch
        {
            // GitHub-API nicht erreichbar oder Rate-Limit erreicht — Badge bleibt einfach unsichtbar.
            stats = null;
        }
    }

    private string UpdatedText
    {
        get
        {
            if (stats is null) return "";
            var days = (int)(DateTime.UtcNow - stats.PushedAt).TotalDays;
            return days switch
            {
                <= 0 => SiteContent.Current.Chrome.GitHubUpdatedToday,
                1 => SiteContent.Current.Chrome.GitHubUpdatedYesterday,
                _ => string.Format(SiteContent.Current.Chrome.GitHubUpdatedDaysAgo, days),
            };
        }
    }

    private sealed class RepoStats
    {
        [System.Text.Json.Serialization.JsonPropertyName("stargazers_count")]
        public int StargazersCount { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("pushed_at")]
        public DateTime PushedAt { get; set; }
    }
}
