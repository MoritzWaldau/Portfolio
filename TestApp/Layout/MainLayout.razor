@inherits LayoutComponentBase
@implements IDisposable
@using TestApp.Data
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="site">
    <div class="ambient" aria-hidden="true">
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>
    </div>

    <NavMenu />

    <main>
        @Body
    </main>

    <footer class="site-footer">
        <div class="container py-5">
            <div class="row gy-4">
                <div class="col-md-4">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <span class="brand-mark" aria-hidden="true">MW</span>
                        <span class="fw-semibold footer-name">@SiteContent.Name</span>
                    </div>
                    <p class="footer-tagline mb-0">@SiteContent.Tagline</p>
                </div>
                <div class="col-md-4">
                    <h3 class="footer-heading">Sitemap</h3>
                    <nav class="d-flex flex-column gap-2">
                        <a href="/#ueber-mich">Über mich</a>
                        <a href="/#skills">Skills</a>
                        <a href="/#projekte">Projekte</a>
                        <a href="/#werdegang">Werdegang</a>
                        <a href="/#kontakt">Kontakt</a>
                    </nav>
                </div>
                <div class="col-md-4">
                    <h3 class="footer-heading">Rechtliches &amp; Social</h3>
                    <nav class="d-flex flex-column gap-2 mb-3">
                        <a href="impressum">Impressum</a>
                        <a href="datenschutz">Datenschutz</a>
                    </nav>
                    <div class="d-flex gap-2">
                        @if (SiteContent.IsProvided(SiteContent.GitHubUrl))
                        {
                            <a class="icon-btn" href="@SiteContent.GitHubUrl" target="_blank" rel="noopener" aria-label="GitHub">
                                <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/></svg>
                            </a>
                        }
                        @if (SiteContent.IsProvided(SiteContent.LinkedInUrl))
                        {
                            <a class="icon-btn" href="@SiteContent.LinkedInUrl" target="_blank" rel="noopener" aria-label="LinkedIn">
                                <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M0 1.15C0 .52.53 0 1.19 0h13.62C15.47 0 16 .52 16 1.15v13.7c0 .63-.53 1.15-1.19 1.15H1.19C.53 16 0 15.48 0 14.85V1.15Zm4.94 12.32V6.16H2.42v7.31h2.52ZM3.68 5.13c.88 0 1.43-.58 1.43-1.31-.02-.74-.55-1.31-1.41-1.31-.86 0-1.43.57-1.43 1.31 0 .73.55 1.31 1.39 1.31h.02Zm4.59 8.34v-4.08c0-.22.02-.44.08-.6.18-.44.58-.9 1.26-.9.89 0 1.24.68 1.24 1.68v3.9h2.52V9.24c0-2.33-1.24-3.41-2.9-3.41-1.34 0-1.93.74-2.26 1.26h.02v-1.08H6.72c.03.71 0 7.31 0 7.31h2.55Z"/></svg>
                            </a>
                        }
                    </div>
                </div>
            </div>
            <hr class="footer-divider" />
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2 footer-bottom">
                <span>© @DateTime.Now.Year @SiteContent.Name</span>
                <span>Gebaut mit Blazor WebAssembly &amp; ☕ — gehostet auf GitHub Pages</span>
            </div>
        </div>
    </footer>

    <button type="button" class="icon-btn back-to-top" data-back-to-top aria-label="Nach oben scrollen">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
    </button>
</div>

@code {
    // Der Blazor-Router scrollt bei Anker-Links (z.B. /#projekte) nicht selbst zur Sektion.
    protected override void OnInitialized() => Nav.LocationChanged += OnLocationChanged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ScrollToFragmentAsync();
        }
    }

    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
        => await ScrollToFragmentAsync();

    private async Task ScrollToFragmentAsync()
    {
        var fragment = new Uri(Nav.Uri).Fragment;
        if (fragment.Length > 1)
        {
            await JS.InvokeVoidAsync("scrollToFragment", fragment[1..]);
        }
    }

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;
}
