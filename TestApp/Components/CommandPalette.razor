@implements IDisposable
@inject NavigationManager Nav
@inject IJSRuntime JS

<button type="button" class="cmdk-trigger" @onclick="Open" aria-label="Command palette öffnen (Strg/Cmd+K)">
    <svg viewBox="0 0 24 24" aria-hidden="true" width="16" height="16" style="fill:none;stroke:currentColor;stroke-width:2"><path d="m21 21-4.34-4.34M19 11a8 8 0 1 1-16 0 8 8 0 0 1 16 0Z"/></svg>
    <kbd>Ctrl K</kbd>
</button>

@if (isOpen)
{
    <div class="cmdk-backdrop" @onclick="Close">
        <div class="cmdk-panel" @onclick:stopPropagation="true" role="dialog" aria-modal="true" aria-label="Command palette">
            <div class="cmdk-input-row">
                <svg class="cmdk-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="m21 21-4.34-4.34M19 11a8 8 0 1 1-16 0 8 8 0 0 1 16 0Z"/></svg>
                <input @ref="inputRef" class="cmdk-input" type="text" value="@query" @oninput="OnInput" @onkeydown="OnKeyDown"
                       placeholder="@SiteContent.Current.Chrome.CmdkPlaceholder" autocomplete="off" />
                <kbd class="cmdk-kbd">Esc</kbd>
            </div>
            <ul class="cmdk-list">
                @for (var i = 0; i < filtered.Count; i++)
                {
                    var item = filtered[i];
                    var idx = i;
                    <li class="cmdk-item @(idx == activeIndex ? "is-active" : "")"
                        @onclick="() => Run(item)" @onmouseenter="() => activeIndex = idx">
                        <span class="cmdk-item-icon" aria-hidden="true">@((MarkupString)item.Icon)</span>
                        <span class="cmdk-item-label">@item.Label</span>
                        <span class="cmdk-item-group">@item.Group</span>
                    </li>
                }
                @if (filtered.Count == 0)
                {
                    <li class="cmdk-empty">@SiteContent.Current.Chrome.CmdkNoResults</li>
                }
            </ul>
        </div>
    </div>
}

@code {
    private const string IconSection = "<svg viewBox=\"0 0 24 24\"><path d=\"M3 12h18M3 6h18M3 18h18\"/></svg>";
    private const string IconProject = "<svg viewBox=\"0 0 24 24\"><rect x=\"3\" y=\"4\" width=\"18\" height=\"16\" rx=\"2\"/><path d=\"M3 9h18\"/></svg>";
    private const string IconLang = "<svg viewBox=\"0 0 24 24\"><circle cx=\"12\" cy=\"12\" r=\"9\"/><path d=\"M3 12h18M12 3a14 14 0 0 1 0 18 14 14 0 0 1 0-18Z\"/></svg>";
    private const string IconExternal = "<svg viewBox=\"0 0 24 24\"><path d=\"M14 3h7v7M21 3l-9 9M5 5h6v14H5V5z\"/></svg>";

    private bool isOpen;
    private bool shouldFocus;
    private string query = "";
    private int activeIndex;
    private ElementReference inputRef;
    private DotNetObjectReference<CommandPalette>? dotNetRef;
    private List<CmdItem> allItems = new();
    private List<CmdItem> filtered = new();

    private sealed record CmdItem(string Label, string Group, string Icon, Action Run);

    protected override void OnInitialized()
    {
        SiteContent.LanguageChanged += OnLanguageChanged;
        BuildItems();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("initCommandPalette", dotNetRef);
        }

        if (shouldFocus)
        {
            shouldFocus = false;
            await JS.InvokeVoidAsync("focusElement", inputRef);
        }
    }

    private void OnLanguageChanged()
    {
        BuildItems();
        StateHasChanged();
    }

    private void BuildItems()
    {
        var c = SiteContent.Current;
        var items = new List<CmdItem>
        {
            new(c.Chrome.NavAbout, c.Chrome.CmdkSectionNav, IconSection, () => GoTo("/#ueber-mich")),
            new(c.Chrome.NavSkills, c.Chrome.CmdkSectionNav, IconSection, () => GoTo("/#skills")),
            new(c.Chrome.NavProjects, c.Chrome.CmdkSectionNav, IconSection, () => GoTo("/#projekte")),
            new(c.Chrome.NavCareer, c.Chrome.CmdkSectionNav, IconSection, () => GoTo("/#werdegang")),
            new(c.Chrome.NavContact, c.Chrome.CmdkSectionNav, IconSection, () => GoTo("/#kontakt")),
        };

        foreach (var project in c.FeaturedProjects)
        {
            items.Add(new(project.Title, c.Chrome.CmdkSectionProjects, IconProject, () => GoTo($"/projekte/{project.Slug}")));
        }

        items.Add(new(SiteContent.IsEnglish ? "Deutsch" : "English", c.Chrome.CmdkSectionActions, IconLang, ToggleLanguage));

        if (SiteContent.IsProvided(SiteContent.GitHubUrl))
        {
            items.Add(new("GitHub", c.Chrome.CmdkSectionActions, IconExternal, () => OpenExternal(SiteContent.GitHubUrl)));
        }

        if (SiteContent.IsProvided(SiteContent.LinkedInUrl))
        {
            items.Add(new("LinkedIn", c.Chrome.CmdkSectionActions, IconExternal, () => OpenExternal(SiteContent.LinkedInUrl)));
        }

        allItems = items;
        Filter();
    }

    private void Filter()
    {
        filtered = string.IsNullOrWhiteSpace(query)
            ? allItems
            : allItems.Where(i => i.Label.Contains(query, StringComparison.OrdinalIgnoreCase)).ToList();
        activeIndex = 0;
    }

    private void OnInput(ChangeEventArgs e)
    {
        query = e.Value?.ToString() ?? "";
        Filter();
    }

    private void OnKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "ArrowDown":
                if (filtered.Count > 0) activeIndex = (activeIndex + 1) % filtered.Count;
                break;
            case "ArrowUp":
                if (filtered.Count > 0) activeIndex = (activeIndex - 1 + filtered.Count) % filtered.Count;
                break;
            case "Enter":
                if (filtered.Count > 0) Run(filtered[activeIndex]);
                break;
            case "Escape":
                Close();
                break;
        }
    }

    private void Run(CmdItem item)
    {
        Close();
        item.Run();
    }

    private void Open()
    {
        query = "";
        BuildItems();
        isOpen = true;
        shouldFocus = true;
    }

    private void Close() => isOpen = false;

    private void GoTo(string url) => Nav.NavigateTo(url);

    private void ToggleLanguage()
    {
        SiteContent.SetLanguage(!SiteContent.IsEnglish);
        _ = JS.InvokeVoidAsync("localStorage.setItem", "lang", SiteContent.IsEnglish ? "en" : "de");
    }

    private void OpenExternal(string url) => _ = JS.InvokeVoidAsync("open", url, "_blank");

    [JSInvokable]
    public void Toggle()
    {
        if (isOpen)
        {
            Close();
        }
        else
        {
            Open();
        }
        StateHasChanged();
    }

    [JSInvokable]
    public void CloseIfOpen()
    {
        if (!isOpen) return;
        Close();
        StateHasChanged();
    }

    public void Dispose()
    {
        SiteContent.LanguageChanged -= OnLanguageChanged;
        dotNetRef?.Dispose();
    }
}
