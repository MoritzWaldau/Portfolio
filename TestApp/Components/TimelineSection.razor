<section id="werdegang" class="section section-alt">
    <div class="container">
        <p class="section-kicker reveal">@SiteContent.SectionCopy.TimelineKicker</p>
        <h2 class="section-title reveal">@SiteContent.SectionCopy.TimelineTitle</h2>
        <div class="timeline reveal">
            @foreach (var (entry, index) in SiteContent.Career.Select((e, i) => (e, i)))
            {
                <div class="timeline-entry reveal reveal-left" style="--reveal-delay: @(index + 1)">
                    <div class="timeline-marker"></div>
                    <div class="timeline-content">
                        <span class="timeline-period">
                            @entry.Period
                            @if (index == 0)
                            {
                                <span class="timeline-current-badge"><span class="dot"></span>Aktuell</span>
                            }
                        </span>
                        <h3 class="h5 mb-1">@entry.Role</h3>
                        <p class="timeline-org mb-1">@entry.Organization</p>
                        <p class="mb-0 text-muted">@entry.Description</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
