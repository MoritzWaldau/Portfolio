@implements IDisposable

<section id="projekte" class="section">
    <div class="container">
        <p class="section-kicker reveal">@SiteContent.Current.SectionCopy.ProjectsKicker</p>
        <h2 class="section-title reveal">@SiteContent.Current.SectionCopy.ProjectsTitle</h2>
        <p class="section-intro reveal mb-5">@SiteContent.Current.SectionCopy.ProjectsIntro</p>

        @foreach (var (project, index) in SiteContent.Current.FeaturedProjects.Select((p, i) => (p, i)))
        {
            <div class="featured-card card gradient-border spot-card reveal" style="--reveal-delay: @index">
                <div class="row g-4 align-items-center">
                    <div class="col-lg-7">
                        <span class="featured-kicker">@project.Kicker</span>
                        <h3 class="h3 card-title">@project.Title</h3>
                        <GitHubActivityBadge Repo="@RepoPath(project)" />
                        <p class="card-text">@project.Description</p>
                        <ul class="feature-list">
                            @foreach (var (highlight, hIndex) in project.Highlights.Select((h, i) => (h, i)))
                            {
                                <li class="reveal" style="--reveal-delay: @hIndex">
                                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m5 13 4 4L19 7"/></svg>
                                    <span>@highlight</span>
                                </li>
                            }
                        </ul>
                        <div class="d-flex flex-wrap gap-2 mb-3">
                            @foreach (var tech in project.Technologies)
                            {
                                <span class="badge tech-badge">@tech</span>
                            }
                        </div>
                        <a class="btn btn-accent" href="@project.RepoUrl" target="_blank" rel="noopener">
                            <svg viewBox="0 0 16 16" width="16" height="16" class="me-2" style="fill:currentColor;vertical-align:-2px" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/></svg>
                            @SiteContent.Current.Chrome.ViewOnGitHub
                        </a>
                        <a class="btn btn-outline-primary ms-2" href="@("/projekte/" + project.Slug)">
                            @SiteContent.Current.Chrome.ProjectDetailMore →
                        </a>
                    </div>
                    <div class="col-lg-5 d-none d-lg-block">
                        <div class="project-graphic" aria-hidden="true">
                            @ProjectGraphics.Render(project.Graphic)
                        </div>
                    </div>
                </div>
            </div>
        }

        <h3 class="projects-subtitle reveal">@SiteContent.Current.SectionCopy.ProjectsSecondaryTitle</h3>
        <div class="row g-4">
            @foreach (var (project, index) in SiteContent.Current.Projects.Select((p, i) => (p, i)))
            {
                <div class="col-md-4 reveal" style="--reveal-delay: @index">
                    <div class="card tilt h-100">
                        <div class="card-body d-flex flex-column">
                            <h3 class="card-title h5">@project.Title</h3>
                            <p class="card-text flex-grow-1">@project.Description</p>
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                @foreach (var tech in project.Technologies)
                                {
                                    <span class="badge tech-badge">@tech</span>
                                }
                            </div>
                            @if (project.Link is not null)
                            {
                                <a class="btn btn-sm btn-outline-primary align-self-start"
                                   href="@project.Link" target="_blank" rel="noopener">@SiteContent.Current.Chrome.ViewProject</a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

@code {
    protected override void OnInitialized() => SiteContent.LanguageChanged += StateHasChanged;

    public void Dispose() => SiteContent.LanguageChanged -= StateHasChanged;

    private static string RepoPath(FeaturedProject project) => project.RepoUrl.Replace("https://github.com/", "");
}
