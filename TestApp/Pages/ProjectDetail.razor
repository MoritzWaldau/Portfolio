@page "/projekte/{Slug}"
@layout MainLayout
@implements IDisposable

@if (Project is null)
{
    <PageTitle>@SiteContent.Current.Chrome.NotFoundTitle – @SiteContent.Name</PageTitle>
    <section class="section text-center">
        <div class="container">
            <h1 class="section-title no-reveal">@SiteContent.Current.Chrome.NotFoundTitle</h1>
            <p class="lead mb-4">@SiteContent.Current.Chrome.NotFoundLead</p>
            <a class="btn btn-accent btn-lg" href="#projekte">@SiteContent.Current.Chrome.NotFoundProjects</a>
        </div>
    </section>
}
else
{
    var project = Project;
    <PageTitle>@project.Title – @SiteContent.Name</PageTitle>

    <section class="section">
        <div class="container">
            <a class="btn btn-link btn-sm mb-4 print-cv-link" href="#projekte">@SiteContent.Current.Chrome.ProjectDetailBack</a>

            <span class="featured-kicker">@project.Kicker</span>
            <h1 class="section-title no-reveal">@project.Title</h1>
            <GitHubActivityBadge Repo="@RepoPath(project)" />

            <div class="row g-5 align-items-start mt-2">
                <div class="col-lg-7">
                    <p class="lead">@project.Description</p>

                    <h2 class="h5 mt-4">@SiteContent.Current.Chrome.ProjectDetailHighlights</h2>
                    <ul class="feature-list">
                        @foreach (var highlight in project.Highlights)
                        {
                            <li>
                                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m5 13 4 4L19 7"/></svg>
                                <span>@highlight</span>
                            </li>
                        }
                    </ul>

                    <h2 class="h5 mt-4">@SiteContent.Current.Chrome.ProjectDetailTechStack</h2>
                    <div class="d-flex flex-wrap gap-2 mb-4">
                        @foreach (var tech in project.Technologies)
                        {
                            <span class="badge tech-badge">@tech</span>
                        }
                    </div>

                    <a class="btn btn-accent" href="@project.RepoUrl" target="_blank" rel="noopener">
                        <svg viewBox="0 0 16 16" width="16" height="16" class="me-2" style="fill:currentColor;vertical-align:-2px" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/></svg>
                        @SiteContent.Current.Chrome.ViewOnGitHub
                    </a>
                </div>
                <div class="col-lg-5">
                    <div class="project-graphic project-graphic-lg" aria-hidden="true">
                        @ProjectGraphics.Render(project.Graphic)
                    </div>
                </div>
            </div>
        </div>
    </section>
}

@code {
    [Parameter] public string Slug { get; set; } = "";

    private FeaturedProject? Project => SiteContent.Current.FeaturedProjects.FirstOrDefault(p => p.Slug == Slug);

    protected override void OnInitialized() => SiteContent.LanguageChanged += StateHasChanged;

    public void Dispose() => SiteContent.LanguageChanged -= StateHasChanged;

    private static string RepoPath(FeaturedProject project) => project.RepoUrl.Replace("https://github.com/", "");
}
