<section id="projekte" class="section">
    <div class="container">
        <h2 class="section-title reveal">Projekte</h2>
        <div class="row g-4">
            @foreach (var (project, index) in SiteContent.Projects.Select((p, i) => (p, i)))
            {
                <div class="col-md-6 reveal" style="--reveal-delay: @index">
                    <div class="card tilt h-100">
                        <div class="card-body d-flex flex-column">
                            <h3 class="card-title h5">@project.Title</h3>
                            <p class="card-text flex-grow-1">@project.Description</p>
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                @foreach (var tech in project.Technologies)
                                {
                                    <span class="badge tech-badge">@tech</span>
                                }
                            </div>
                            @if (project.Link is not null)
                            {
                                <a class="btn btn-sm btn-outline-primary align-self-start"
                                   href="@project.Link" target="_blank" rel="noopener">Zum Projekt</a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
