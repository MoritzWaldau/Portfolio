@page "/not-found"
@layout MainLayout

<PageTitle>Seite nicht gefunden – @SiteContent.Name</PageTitle>

<section class="section text-center">
    <div class="container">
        <div class="nf-code" aria-hidden="true">404</div>
        <h1 class="section-title no-reveal">Diese Seite ist im Deployment verloren gegangen.</h1>
        <p class="lead mb-4">Die gesuchte Seite existiert leider nicht.</p>
        <div class="d-flex justify-content-center gap-3">
            <a class="btn btn-accent btn-lg" href="/">Zur Startseite</a>
            <a class="btn btn-outline-primary btn-lg" href="/#projekte">Zu den Projekten</a>
        </div>
    </div>
</section>
