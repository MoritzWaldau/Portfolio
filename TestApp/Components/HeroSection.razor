@using System.Text.Json
@implements IDisposable

<section id="start" class="hero">
    <canvas class="hero-canvas" aria-hidden="true"></canvas>
    <div class="container">
        <div class="row align-items-center gy-4">
            <div class="col-md-8">
                <p class="hero-kicker mb-2 hero-anim hero-anim-1">@SiteContent.Current.JobTitle</p>
                <h1 class="hero-name split-letters">@SiteContent.Name</h1>
                <p class="hero-tagline hero-anim hero-anim-3" @key="SiteContent.Current">
                    @SiteContent.Current.Chrome.HeroLeadIn <span class="tw-word" data-typewriter="@TypewriterJson">@SiteContent.Current.TypewriterWords[0]</span><span class="tw-caret" aria-hidden="true"></span>
                </p>
                <div class="d-flex gap-3 mt-4 hero-anim hero-anim-4">
                    <a class="btn btn-accent btn-lg" href="#kontakt">@SiteContent.Current.Chrome.HeroCtaContact</a>
                    <a class="btn btn-outline-light btn-lg" href="#projekte">@SiteContent.Current.Chrome.HeroCtaProjects</a>
                </div>
            </div>
            <div class="col-md-4 text-center hero-anim hero-anim-5">
                <div class="hero-portrait-wrap">
                    <div class="hero-portrait @(SiteContent.IsProvided(SiteContent.PortraitPath) ? "" : "no-photo")">
                        @if (SiteContent.IsProvided(SiteContent.PortraitPath))
                        {
                            <img src="@SiteContent.PortraitPath" alt="Porträt von @SiteContent.Name"
                                 onerror="this.closest('.hero-portrait').classList.add('no-photo')" />
                        }
                        <span class="hero-initials" aria-hidden="true">@Initials</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    protected override void OnInitialized() => SiteContent.LanguageChanged += StateHasChanged;

    public void Dispose() => SiteContent.LanguageChanged -= StateHasChanged;

    private static string Initials => string.Concat(
        SiteContent.Name.Split(' ', StringSplitOptions.RemoveEmptyEntries).Select(p => p[0]));

    private static string TypewriterJson => JsonSerializer.Serialize(SiteContent.Current.TypewriterWords);
}
