@page "/not-found"
@layout MainLayout
@implements IDisposable

<PageTitle>Seite nicht gefunden – @SiteContent.Name</PageTitle>

<section class="section text-center">
    <div class="container">
        <div class="nf-code" aria-hidden="true">404</div>
        <h1 class="section-title no-reveal">@SiteContent.Current.Chrome.NotFoundTitle</h1>
        <p class="lead mb-4">@SiteContent.Current.Chrome.NotFoundLead</p>
        <div class="d-flex justify-content-center gap-3">
            <a class="btn btn-accent btn-lg" href=".">@SiteContent.Current.Chrome.NotFoundHome</a>
            <a class="btn btn-outline-primary btn-lg" href="#projekte">@SiteContent.Current.Chrome.NotFoundProjects</a>
        </div>
    </div>
</section>

@code {
    protected override void OnInitialized() => SiteContent.LanguageChanged += StateHasChanged;

    public void Dispose() => SiteContent.LanguageChanged -= StateHasChanged;
}
